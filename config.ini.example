[api]
# AniWorld API Server (Scraping + Stream-Resolution)
port = 5080
db_path = /opt/aniworld/data/aniworld.db
# Wie lange ein fehlgeschlagener Hoster übersprungen wird (in Minuten, default: 30)
fail_ttl_minutes = 30

[metadata]
# AniWorld Metadata Server (AniList/MAL/AniDB)
port = 5090
db_path = /opt/aniworld/data/metadata.db
covers_dir = /opt/aniworld/data/covers
anidb_titles_path = /opt/aniworld/data/anidb-titles.xml.gz

[proxy]
# Stream Proxy (für .strm Redirect)
port = 5081
# Segment Pre-Fetch Buffer (Anzahl Segmente die vorgeladen werden, 0 = deaktiviert)
prefetch_segments = 5
# Externe URL für .strm Files + m3u8 Playlists (leer = http://localhost:PORT)
# Nötig wenn Clients von aussen zugreifen (z.B. Windows/Samsung App via Reverse-Proxy)
# base_url = https://proxy.stream.example.com
# Stream-Token: Authentifizierung für /play/ und /stream/ Endpoints (leer = kein Auth)
# Ohne gültigen Token gibt es 403 Forbidden
# stream_token = EIN_LANGER_ZUFALLS_STRING
# Dashboard auf separatem Port (nur 127.0.0.1, Tunnel-Zugang)
# Wenn gesetzt: Proxy-Port ist public (nur Streams), Dashboard-Port ist private
# dashboard_port = 5082

[sync]
# Pfad für .strm/.nfo Dateien (Emby Library zeigt hierhin)
media_path = /media/aniworld
# Parallele Worker (default: 2, höher = schneller aber mehr RAM/CPU + aniworld.to Throttling)
workers = 2

[anidb]
# AniDB Client (registrieren unter https://anidb.net/software/add)
# Ohne Client werden AniDB-Episodentitel übersprungen
client = REGISTER_PENDING
client_version = 1

[preferences]
language = Deutsch
hoster = VOE

[emby]
# Emby Server (für Auto Library Scan nach Sync)
# url = http://localhost:8096
# api_key = YOUR_EMBY_API_KEY
# library_name = AniWorld
